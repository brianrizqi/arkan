{
    "version": 2,
    "builds": [
        { "src": "package.json", "use": "@vercel/node", "config": { "buildCommand": "npm run build" } },
        { "src": "/api/index.php", "use": "vercel-php@0.7.1", "config": { "includeFiles": "public/build/**" } },
        { "src": "/public/**", "use": "@vercel/static" }
    ],
    "routes": [
        { "src": "/build/(.*)", "dest": "/public/build/$1" },
        { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
        { "src": "/favicon.ico", "dest": "/public/favicon.ico" },
        { "src": "/robots.txt", "dest": "/public/robots.txt" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "env": {
        "APP_URL": "https://arkan-three.vercel.app",
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "VIEW_COMPILED_PATH": "/tmp/views",
        "SESSION_DRIVER": "cookie",
        "CACHE_STORE": "array",
        "LOG_CHANNEL": "stderr"
    }
}